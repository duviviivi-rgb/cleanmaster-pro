<Window x:Class="CleanMasterPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CleanMasterPro"
        mc:Ignorable="d"
        Title="CleanMaster Pro" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>
        
        <!-- 顶部导航 -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Background="#3498db" Padding="10">
            <Button Content="快速扫描" Margin="5" Width="100"/>
            <Button Content="深度清理" Margin="5" Width="100"/>
            <Button Content="空间分析" Margin="5" Width="100"/>
            <Button Content="系统优化" Margin="5" Width="100"/>
            <Button Content="设置" Margin="5" Width="100"/>
        </StackPanel>
        
        <!-- 中央内容区域 -->
        <Grid Grid.Row="1" Grid.Column="0" Background="#f8f9fa" Padding="10">
            <TextBlock Text="欢迎使用CleanMaster Pro" FontSize="24" FontWeight="Bold" Margin="0 20 0 20"/>
            <TextBlock Text="智能磁盘清理与数据治理工具" FontSize="16" Margin="0 60 0 20"/>
            <Button Content="开始扫描" Width="150" Height="50" FontSize="16" Margin="0 100 0 0" HorizontalAlignment="Left"/>
        </Grid>
        
        <!-- 右侧信息栏 -->
        <Grid Grid.Row="1" Grid.Column="1" Background="#e9ecef" Padding="10">
            <TextBlock Text="磁盘信息" FontWeight="Bold" Margin="0 10 0 10"/>
            <TextBlock Text="C盘: 50% 已使用" Margin="0 40 0 10"/>
            <TextBlock Text="D盘: 30% 已使用" Margin="0 70 0 10"/>
            <TextBlock Text="E盘: 20% 已使用" Margin="0 100 0 10"/>
            <TextBlock Text="清理建议" FontWeight="Bold" Margin="0 140 0 10"/>
            <TextBlock Text="清理临时文件" Margin="0 170 0 10"/>
            <TextBlock Text="清理浏览器缓存" Margin="0 200 0 10"/>
        </Grid>
        
        <!-- 底部操作栏 -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Background="#e9ecef" Padding="10" HorizontalAlignment="Right">
            <Button Content="开始清理" Margin="5" Width="100"/>
            <Button Content="暂停" Margin="5" Width="100"/>
            <Button Content="取消" Margin="5" Width="100"/>
        </StackPanel>
    </Grid>
</Window>